<%- include('partials/header') %>

<h1><%= title %></h1>

<form action="/edit-project/<%= project.project_id %>" method="POST">
    <div>
        <label for="title">Project Title:</label>
        <input type="text" id="title" name="title" value="<%= project.title %>" required maxlength="200">
    </div>

    <div>
        <label for="description">Description:</label>
        <textarea id="description" name="description" required maxlength="1000"><%= project.description %></textarea>
    </div>

    <div>
        <label for="location">Location:</label>
        <input type="text" id="location" name="location" value="<%= project.location %>" required maxlength="255">
    </div>

    <div>
        <label for="date">Date:</label>
        <input type="date" id="date" name="date" value="<%= project.date ? new Date(project.date).toISOString().split('T')[0] : '' %>" required>
    </div>

    <div>
        <label for="organizationId">Sponsoring Organization:</label>
        <select id="organizationId" name="organizationId" required>
            <% organizations.forEach(org => { %>
                <option value="<%= org.organization_id %>" <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                    <%= org.name %>
                </option>
            <% }); %>
        </select>
    </div>

    <button type="submit">Update Project</button>
</form>

<%- include('partials/footer') %>