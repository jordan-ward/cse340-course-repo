<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>
    
    <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { timeZone: 'UTC' }) %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    <p><strong>Description:</strong> <%= project.description %></p>
    
    <p><strong>Partner Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>

    <h3>Categories:</h3>
    <% if (categories && categories.length > 0) { %>
        <ul class="category-tags">
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.category_id %>"><%= category.category_name %></a>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No categories assigned to this project.</p>
    <% } %>

    <a href="/edit-project/<%= project.project_id %>" class="btn">Edit Project</a>
    <p><a href="/assign-categories/<%= project.project_id %>">Edit Categories</a></p>
    

</main>

<%- include('partials/footer') %>