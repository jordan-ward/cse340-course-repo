<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    
    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                
                <% 
                    const formattedDate = new Date(project.project_date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                        timeZone: 'UTC'
                    });
                %>
                
                <li>
                    <strong><%= formattedDate %>:</strong> <%= project.title %> (<em><%= project.organization_name %></em>)
                </li>

            <% }) %>
        </ul>
    <% } else { %>
        <p>No service projects are currently available.</p>
    <% } %>

</main>
<%- include('partials/footer') %>