<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <% if (categories && categories.length > 0) { %>
        <ul>
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.category_id %>"><%= category.category_name %></a>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No categories found.</p>
    <% } %>
</main>

<%- include('partials/footer') %>