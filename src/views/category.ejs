<%- include('partials/header') %>

<main>
    <h1><%= category.category_name %> Projects</h1>
    <p>Service projects focused on <%= category.category_name.toLowerCase() %>.</p>

    <% if (projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <strong>
                        <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                    </strong>
                    <span>
                        &nbsp;- <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
                    </span>
                </li>
            <% }); %>
        </ul>
    <% } else { %>
        <p>No service projects are currently available for this category.</p>
    <% } %>
</main>

<%- include('partials/footer') %>